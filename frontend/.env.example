# ========================================
# AIDA Frontend - Environment Configuration Template
# ========================================
# Copy this file to .env and adjust values as needed.
# ========================================

# Backend API URL
# Default in Docker/dev: /api (served through Vite proxy)
# Optional override: set VITE_PROXY_TARGET for the dev server target
VITE_API_URL=/api
VITE_PROXY_TARGET=http://backend:8000
