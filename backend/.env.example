# ========================================
# APPLICATION METADATA
# ========================================
PROJECT_NAME=AIDA
PROJECT_TAGLINE=AI-Driven Security Audit Platform
PROJECT_DESCRIPTION=Intelligent autonomous penetration testing powered by AI
VERSION=1.0.0-alpha
API_V1_PREFIX=/api

# ========================================
# DATABASE CREDENTIALS
# IMPORTANT: Change these values in production!
# ========================================
POSTGRES_USER=aida
POSTGRES_PASSWORD=aida_secure_password_change_me
POSTGRES_DB=aida_assessments
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL (auto-constructed from above values in config.py)
# Format: postgresql://{user}:{password}@{host}:{port}/{database}
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ========================================
# CORS ORIGINS
# Comma-separated list of allowed origins
# Production: Add your frontend domain
# ========================================
BACKEND_CORS_ORIGINS=*

# ========================================
# CONTAINER CONFIGURATION
# Default: aida-pentest (built-in). Set to your Exegol container name if using Exegol.
# ========================================
CONTAINER_WORKSPACE_BASE=/workspace
DEFAULT_CONTAINER_NAME=aida-pentest
COMMAND_TIMEOUT=300

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=logs
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# ========================================
# BACKEND API URL (for MCP / agent service)
# In Docker backend container, use the internal app port.
# ========================================
BACKEND_API_URL=http://localhost:8000/api

# ========================================
# OPENAI-COMPATIBLE LLM CONFIGURATION
# Examples: OpenAI, DeepSeek, GLM, local gateways
# ========================================
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
AGENT_MODEL=gpt-4-turbo

# ========================================
# SECURITY (Future use)
# ========================================
# Uncomment and set a strong secret key in production
# SECRET_KEY=your-super-secret-key-min-32-chars-change-me-in-production
# ENCRYPT_CREDENTIALS=false

# ========================================
# DEVELOPMENT / PRODUCTION
# ========================================
ENVIRONMENT=development
DEBUG=false
