# ========================================
# .env.docker - Configuration for Docker deployment
# ========================================
# This file is an EXAMPLE for Docker-based deployment.
# Copy this file to .env and adjust values as needed.
#
# KEY DIFFERENCES from non-Docker .env:
# - POSTGRES_HOST: Use 'postgres' (Docker service name) instead of 'localhost'
# - DATABASE_URL: Use 'postgres' hostname instead of 'localhost'
# - BACKEND_API_URL: Keep as localhost for MCP (which runs on host, not in Docker)
# ========================================

# ========================================
# APPLICATION METADATA
# ========================================
PROJECT_NAME=AIDA
PROJECT_TAGLINE=AI-Driven Security Audit Platform
PROJECT_DESCRIPTION=Intelligent autonomous penetration testing powered by AI
VERSION=1.0.0-alpha
API_V1_PREFIX=/api

# ========================================
# DATABASE CREDENTIALS
# IMPORTANT: Change these values in production!
# ========================================
POSTGRES_USER=aida
POSTGRES_PASSWORD=aida
POSTGRES_DB=aida_assessments
# IMPORTANT: Use 'postgres' (Docker service name) instead of 'localhost'
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database URL (auto-constructed from above in config.py)
# For Docker: Use postgres service name instead of localhost
DATABASE_URL=postgresql://aida:aida@postgres:5432/aida_assessments

# ========================================
# CORS ORIGINS
# ========================================
BACKEND_CORS_ORIGINS=*

# ========================================
# CONTAINER CONFIGURATION
# Default: aida-pentest (built-in). Set to your Exegol container name if using Exegol.
# ========================================
CONTAINER_WORKSPACE_BASE=/workspace
DEFAULT_CONTAINER_NAME=aida-pentest
COMMAND_TIMEOUT=300

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=logs
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# ========================================
# BACKEND API URL (for MCP / agent service inside backend container)
# IMPORTANT: Use the app's internal port inside the backend container.
# ========================================
BACKEND_API_URL=http://localhost:8000/api

# ========================================
# OPENAI-COMPATIBLE LLM CONFIGURATION
# Examples: OpenAI, DeepSeek, GLM, local gateways
# ========================================
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
AGENT_MODEL=gpt-4-turbo

# ========================================
# DEVELOPMENT / PRODUCTION
# ========================================
ENVIRONMENT=development
DEBUG=false
